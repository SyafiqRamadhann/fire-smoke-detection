# Application
APP_NAME="Fire & Smoke Detection"
APP_VERSION="1.0.0"
DEBUG=True
SECRET_KEY="ganti-dengan-secret-key-anda-yang-panjang-dan-acak"

# Server
HOST=0.0.0.0
PORT=8000

# Model
MODEL_PATH=weights/best.pt
CONFIDENCE_THRESHOLD=0.35
IOU_THRESHOLD=0.10

# Upload limits
MAX_IMAGE_SIZE_MB=10
MAX_VIDEO_SIZE_MB=500
ALLOWED_IMAGE_TYPES=jpg,jpeg,png
ALLOWED_VIDEO_TYPES=mp4,avi,mov

# Paths
UPLOAD_DIR=uploads
OUTPUT_DIR=outputs
DATABASE_DIR=database

# Database
DATABASE_URL=sqlite:///database/detections.db

# WebSocket
WS_MAX_FRAME_SIZE=5242880
CAMERA_FPS_LIMIT=30
